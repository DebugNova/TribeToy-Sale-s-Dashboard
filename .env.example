# TribeToy Dashboard — environment variables
# -------------------------------------------------------------------
# Copy this file to ".env.local" for local development and fill in the
# real values. On Vercel, add these same 4 keys under
# Project → Settings → Environment Variables (see DEPLOYMENT.md).
#
# NEVER commit ".env.local" — it is gitignored. This ".env.example"
# file is safe to commit because it contains placeholders only.
# -------------------------------------------------------------------

# --- Public (sent to the browser — safe to expose) ---
# Supabase → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://itvjtmwteyqqakhtfajd.supabase.co

# Supabase → Project Settings → API Keys → "anon" / publishable key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- Server-only (NEVER expose to the browser) ---
# Supabase → Project Settings → API Keys → "service_role" key.
# Used only by the website intake API (bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret the website uses to HMAC-sign intake webhook requests.
# Generate a strong random value, e.g.:  openssl rand -hex 32
INTAKE_WEBHOOK_SECRET=your-strong-random-secret
